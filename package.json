{
  "name": "mining-farm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:live": "node scripts/start-server.mjs",
    "setup": "node scripts/verify-env.mjs && npm run db:migrate && node scripts/seed-admin.mjs",
    "db:migrate": "prisma migrate deploy",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "admin:addresses": "node scripts/show-admin-wallet.mjs",
    "wallets:verify": "node scripts/verify-wallet-system.mjs",
    "wallets:fix-tron": "npx tsx src/backfill-wallets.ts",
    "plans:add": "npx tsx src/addPlans.ts",
    "admin:create": "npx tsx src/createAdmin.ts",
    "test:smtp": "node scripts/test-smtp.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@react-email/components": "^1.0.12",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "bcryptjs": "^3.0.3",
    "ethers": "^6.16.0",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "next-intl": "^4.13.0",
    "nodemailer": "^7.0.7",
    "otplib": "^13.4.1",
    "pg": "^8.21.0",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "react-qr-code": "^2.2.0",
    "resend": "^6.12.4",
    "tronweb": "^6.3.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
