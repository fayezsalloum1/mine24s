# =============================================================================
# Simple Mining — site configuration (.env)
# Copy this file to .env and fill in your values. Keep .env private.
# =============================================================================

# --- Database (PostgreSQL / Supabase) ---
# Vercel + Prisma: use SESSION pooler on port 5432 (not 6543 transaction pooler).
# Interactive DB transactions fail intermittently on port 6543.
DATABASE_URL="postgresql://postgres.projectref:password@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=require"
# Migrations only (optional if you run migrate locally):
DIRECT_URL="postgresql://postgres:password@db.projectref.supabase.co:5432/postgres?sslmode=require"

# Supabase Auth (Google OAuth) ---
# One variable (recommended for Vercel):
SUPABASE_PUBLIC="https://your-project.supabase.co|your-anon-key"
# Service role (server only) — links email users to Supabase for password reset:
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   https://yourdomain.com/auth/callback
#   http://localhost:3000/auth/callback
# Enable Google under Authentication → Providers
# Enable email templates under Authentication → Email (password reset)

# --- Website URL & login security ---
# NEXTAUTH_URL must match your live domain exactly (https://yourdomain.com)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-use-a-long-random-string"

# --- Admin account (created automatically on npm run start:live) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# --- Deposits: your wallet addresses (recommended — no seed phrase on server) ---
USE_CUSTOM_PLATFORM_WALLET=true
ADMIN_TREASURY_EVM="0xYourEthereumOrBscAddress"
ADMIN_TREASURY_TRC20="TYourTronAddress"

# --- Advanced: HD wallets (optional, not recommended on shared hosting) ---
# USE_CUSTOM_PLATFORM_WALLET=false
# MASTER_WALLET_MNEMONIC="twelve word phrase here"
# ADMIN_WALLET_INDEX=0

# --- Blockchain RPC (optional, for auto deposit detection) ---
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
BSC_RPC_URL=https://bsc-dataseed.binance.org
TRONGRID_API_KEY=

# --- Explorer APIs (recommended — faster deposit detection + "please wait" notifications) ---
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
# TRONSCAN_API_KEY=   # optional alias for TRONGRID_API_KEY
DEPOSIT_MIN_CONFIRMATIONS_ERC20=12
DEPOSIT_MIN_CONFIRMATIONS_BEP20=15
DEPOSIT_MIN_CONFIRMATIONS_TRC20=1
DEPOSIT_MIN_CONFIRMATIONS_SOL=1

# --- Solana (Helius API) ---
HELIUS_API_KEY=
# ADMIN_TREASURY_SOL=   # custom wallet mode only

# --- Background deposit scanner ---
DEPOSIT_SCAN_INTERVAL_MS=120000
DISABLE_DEPOSIT_SCANNER=false
ENABLE_BACKGROUND_SCANNER=true
CRON_SECRET=your-cron-secret

# --- Server port (default 3000) ---
# PORT=3000

# --- Email via Resend (optional — test mode only sends to your own email) ---
# RESEND_API_KEY=re_your-api-key
# SMTP_FROM=onboarding@resend.dev

# --- Email via Brevo (recommended for production — any recipient) ---
# Set EMAIL_PROVIDER=brevo to force Brevo when both Resend and Brevo are configured.
EMAIL_PROVIDER=brevo
# Option A — Brevo API (best on Vercel): Brevo → SMTP & API → API keys
BREVO_API_KEY=xkeysib-your-api-key
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME="Simple Mining"

# Option B — Brevo SMTP: Brevo → SMTP & API → SMTP keys
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login-email@domain.com
# SMTP_PASS=your-brevo-smtp-key
# SMTP_FROM=noreply@yourdomain.com
# SMTP_FROM must be a verified sender in Brevo → Senders & IP

# --- Brand videos (optional — drop MP4/WebM in public/videos/) ---
# NEXT_PUBLIC_HERO_VIDEO_URL=/videos/hero.mp4
# NEXT_PUBLIC_HERO_VIDEO_2_URL=/videos/hero-2.mp4
# NEXT_PUBLIC_AUTH_VIDEO_URL=/videos/auth.mp4
# NEXT_PUBLIC_ABOUT_VIDEO_URL=/videos/about.mp4
# NEXT_PUBLIC_OPERATIONS_VIDEO_URL=/videos/operations.mp4

# --- SMS (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# --- AI support chat (Google AI Studio / Gemini) ---
# Create key at https://aistudio.google.com/apikey (usually starts with AIzaSy)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash,gemini-1.5-flash
# SUPPORT_EMAIL=support@yourdomain.com
