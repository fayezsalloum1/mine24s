# =============================================================================
# Cloud Mining — site configuration (.env)
# Copy this file to .env and fill in your values. Keep .env private.
# =============================================================================

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/miningfarm"

# --- Website URL & login security ---
# NEXTAUTH_URL must match your live domain exactly (https://yourdomain.com)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-use-a-long-random-string"

# --- Admin account (created automatically on npm run start:live) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# --- Deposits: your wallet addresses (recommended — no seed phrase on server) ---
USE_CUSTOM_PLATFORM_WALLET=true
ADMIN_TREASURY_EVM="0xYourEthereumOrBscAddress"
ADMIN_TREASURY_TRC20="TYourTronAddress"

# --- Advanced: HD wallets (optional, not recommended on shared hosting) ---
# USE_CUSTOM_PLATFORM_WALLET=false
# MASTER_WALLET_MNEMONIC="twelve word phrase here"
# ADMIN_WALLET_INDEX=0

# --- Blockchain RPC (optional, for auto deposit detection) ---
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
BSC_RPC_URL=https://bsc-dataseed.binance.org
TRONGRID_API_KEY=

# --- Background deposit scanner ---
DEPOSIT_SCAN_INTERVAL_MS=120000
DISABLE_DEPOSIT_SCANNER=false
ENABLE_BACKGROUND_SCANNER=true
CRON_SECRET=your-cron-secret

# --- Server port (default 3000) ---
# PORT=3000

# --- Email (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- SMS (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
