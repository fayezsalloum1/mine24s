# =============================================================================
# Cloud Mining — site configuration (.env)
# Copy this file to .env and fill in your values. Keep .env private.
# =============================================================================

# --- Database (PostgreSQL / Supabase) ---
# Vercel + Prisma: use SESSION pooler on port 5432 (not 6543 transaction pooler).
# Interactive DB transactions fail intermittently on port 6543.
DATABASE_URL="postgresql://postgres.projectref:password@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=require"
# Migrations only (optional if you run migrate locally):
DIRECT_URL="postgresql://postgres:password@db.projectref.supabase.co:5432/postgres?sslmode=require"

# --- Website URL & login security ---
# NEXTAUTH_URL must match your live domain exactly (https://yourdomain.com)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-use-a-long-random-string"

# --- Admin account (created automatically on npm run start:live) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# --- Deposits: your wallet addresses (recommended — no seed phrase on server) ---
USE_CUSTOM_PLATFORM_WALLET=true
ADMIN_TREASURY_EVM="0xYourEthereumOrBscAddress"
ADMIN_TREASURY_TRC20="TYourTronAddress"

# --- Advanced: HD wallets (optional, not recommended on shared hosting) ---
# USE_CUSTOM_PLATFORM_WALLET=false
# MASTER_WALLET_MNEMONIC="twelve word phrase here"
# ADMIN_WALLET_INDEX=0

# --- Blockchain RPC (optional, for auto deposit detection) ---
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
BSC_RPC_URL=https://bsc-dataseed.binance.org
TRONGRID_API_KEY=

# --- Background deposit scanner ---
DEPOSIT_SCAN_INTERVAL_MS=120000
DISABLE_DEPOSIT_SCANNER=false
ENABLE_BACKGROUND_SCANNER=true
CRON_SECRET=your-cron-secret

# --- Server port (default 3000) ---
# PORT=3000

# --- Email via Resend (recommended) ---
# RESEND_API_KEY=re_your-api-key
# SMTP_FROM=onboarding@resend.dev
# SMTP_FROM_NAME="Cloud Mining"
# onboarding@resend.dev works for testing; add your domain in Resend for production.

# --- Email via Brevo (fallback) ---
# Option A — Brevo API (best on Vercel): Brevo → SMTP & API → API keys
BREVO_API_KEY=xkeysib-your-api-key
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME="Cloud Mining"

# Option B — Brevo SMTP: Brevo → SMTP & API → SMTP keys
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login-email@domain.com
# SMTP_PASS=your-brevo-smtp-key
# SMTP_FROM=noreply@yourdomain.com
# SMTP_FROM must be a verified sender in Brevo → Senders & IP

# --- SMS (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
