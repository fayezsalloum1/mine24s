# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# secrets — never upload .env to a public location
.env
.env.*
!.env.example
*.key
secrets/
wallet*.txt

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# uploaded plan images (folder kept via .gitkeep)
/public/uploads/plans/*
!/public/uploads/plans/.gitkeep
